{
	"name": "ernolf/files_sharing_raw",
	"description": "Serves files raw on the World Wide Web: link directly to file contents without any of Nextcloud's UI.",
	"type": "nextcloud-app",
	"version": "0.5.3",
	"license": "AGPL-3.0-or-later",
	"authors": [
		{
			"name": "[ernolf] Raphael Gradenwitz",
			"email": "raphael.gradenwitz@googlemail.com"
		}
	],
	"config": {
		"platform": {
			"php": "8.1"
		},
		"sort-packages": true,
		"allow-plugins": {
			"bamarni/composer-bin-plugin": true
		},
		"optimize-autoloader": true,
		"autoloader-suffix": "FilesSharingRaw"
	},
	"autoload": {
		"psr-4": {
			"OCA\\FilesSharingRaw\\": "lib/"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"@composer bin all install --ansi"
		],
		"post-update-cmd": [
			"@composer bin all install --ansi"
		],
		"lint": "find . -name \\*.php -not -path './vendor/*' -not -path './vendor-bin/*' -not -path './node_modules/*' -print0 | xargs -0 -n1 php -l",
		"cs:check": "php-cs-fixer fix --dry-run --diff",
		"cs:fix": "php-cs-fixer fix",
		"psalm": "psalm --no-cache --threads=$(nproc)",
		"psalm:update-baseline": "psalm --threads=1 --update-baseline",
		"test:unit": "phpunit -c phpunit.xml --colors=always --testdox --fail-on-warning --fail-on-risky"
	},
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"bamarni/composer-bin-plugin": "^1.9"
	},
	"extra": {
		"bamarni-bin": {
			"bin-links": true,
			"forward-command": false
		}
	}
}
